{
   "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
   "vcs": {
      "enabled": true,
      "clientKind": "git",
      "useIgnoreFile": true
   },
   "files": {
      "ignoreUnknown": false,
      "includes": ["**", "!build", "!node_modules"]
   },
   "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 3,
      "lineWidth": 120,
      "trailingNewline": true
   },
   "linter": {
      "enabled": true,
      "rules": {
         "recommended": true
      }
   },
   "javascript": {
      "formatter": {
         "quoteStyle": "single",
         "arrowParentheses": "always",
         "indentStyle": "space",
         "indentWidth": 3,
         "semicolons": "always",
         "trailingCommas": "all",
         "lineWidth": 120,
         "trailingNewline": true
      }
   },
   "json": {
      "formatter": {
         "indentStyle": "space",
         "indentWidth": 3,
         "lineWidth": 120
      }
   },
   "assist": {
      "enabled": true,
      "actions": {
         "source": {
            "organizeImports": "on"
         }
      }
   }
}
