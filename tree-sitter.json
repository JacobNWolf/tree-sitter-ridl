{
   "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
   "grammars": [
      {
         "name": "ridl",
         "camelcase": "RIDL",
         "title": "RIDL",
         "scope": "source.ridl",
         "file-types": ["ridl"],
         "injection-regex": "^ridl$",
         "class-name": "TreeSitterRidl"
      }
   ],
   "metadata": {
      "version": "0.1.0",
      "license": "MIT",
      "description": "RIDL grammar for tree-sitter",
      "authors": [
         {
            "name": "Jacob Wolf",
            "email": "jacob@jacobwolf.dev",
            "url": "https://github.com/JacobNWolf"
         }
      ],
      "links": {
         "repository": "https://github.com/JacobNWolf/tree-sitter-ridl"
      }
   },
   "bindings": {
      "c": false,
      "go": false,
      "java": false,
      "node": true,
      "python": false,
      "rust": true,
      "swift": false,
      "zig": false
   }
}
